# Root .gitignore for mini-ecommerce-platform
# Ignore node modules and build outputs
node_modules/
dist/
dist-ssr/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Local env files
*.local
.env
.env.*

# Editor directories and files
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# System files
Thumbs.db

# OS generated files
.DS_Store

# Optional: ignore lock files if not shared
# package-lock.json
yarn.lock
pnpm-lock.yaml
